OPENROUTER_API_KEY=
# `openrouter/free` is acceptable for local experiments, but the router may choose
# models with inconsistent structured-output behavior. For reliable Draft
# Automation Creation, use a fixed OpenRouter model whose supported_parameters
# include `response_format` and `structured_outputs`.
OPENROUTER_MODEL=openrouter/free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
